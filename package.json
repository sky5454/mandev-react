    "eslint-plugin-react": "^7.33.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "prettier": "^3.0.1",
    "standard-version": "^9.5.0"
  },
  "config": {
